{
  "summary": "Brownfield Feature Flow",
  "description": "Single configurable flow for a small brownfield feature: onboard an existing or new repo, generate spec/plan/tasks, and optionally create a protocol or sprint.",
  "value": {
    "modules": [
      {
        "id": "onboard_project",
        "value": {
          "type": "script",
          "path": "u/devgodzilla/project_onboard_api",
          "input_transforms": {
            "project_id": { "type": "javascript", "expr": "flow_input.project_id || null" },
            "git_url": { "type": "javascript", "expr": "flow_input.git_url || ''" },
            "project_name": { "type": "javascript", "expr": "flow_input.project_name || ''" },
            "branch": { "type": "javascript", "expr": "flow_input.branch || 'main'" },
            "description": { "type": "javascript", "expr": "flow_input.project_description || ''" },
            "constitution_content": { "type": "javascript", "expr": "flow_input.constitution_content || ''" },
            "run_discovery_agent": { "type": "javascript", "expr": "flow_input.run_discovery_agent || false" },
            "discovery_pipeline": { "type": "javascript", "expr": "flow_input.discovery_pipeline !== false" },
            "discovery_engine_id": { "type": "javascript", "expr": "flow_input.discovery_engine_id || ''" },
            "discovery_model": { "type": "javascript", "expr": "flow_input.discovery_model || ''" },
            "clone_if_missing": { "type": "javascript", "expr": "flow_input.clone_if_missing !== false" }
          }
        },
        "input_transforms": {}
      },
      {
        "id": "speckit_specify",
        "value": {
          "type": "script",
          "path": "u/devgodzilla/speckit_specify_api",
          "input_transforms": {
            "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
            "description": { "type": "javascript", "expr": "flow_input.feature_request" },
            "feature_name": { "type": "javascript", "expr": "flow_input.feature_name || ''" },
            "base_branch": { "type": "javascript", "expr": "flow_input.branch || 'main'" }
          }
        },
        "input_transforms": {}
      },
      {
        "id": "optional_clarify",
        "value": {
          "type": "branchone",
          "branches": [
            {
              "summary": "Clarifications provided",
              "expr": "((flow_input.clarification_entries || []).length > 0) || !!(flow_input.clarification_notes || '').trim()",
              "modules": [
                {
                  "id": "speckit_clarify",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/speckit_clarify_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
                    "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" },
                    "entries": { "type": "javascript", "expr": "flow_input.clarification_entries || []" },
                    "notes": { "type": "javascript", "expr": "flow_input.clarification_notes || ''" }
                  }
                }
              ]
            },
            {
              "summary": "Skip clarifications",
              "expr": "true",
              "modules": []
            }
          ],
          "default": []
        }
      },
      {
        "id": "speckit_plan",
        "value": {
          "type": "script",
          "path": "u/devgodzilla/speckit_plan_api",
          "input_transforms": {
            "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
            "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
            "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" }
          }
        },
        "input_transforms": {}
      },
      {
        "id": "optional_checklist",
        "value": {
          "type": "branchone",
          "branches": [
            {
              "summary": "Generate checklist",
              "expr": "!!flow_input.run_checklist",
              "modules": [
                {
                  "id": "speckit_checklist",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/speckit_checklist_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
                    "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" }
                  }
                }
              ]
            },
            {
              "summary": "Skip checklist",
              "expr": "true",
              "modules": []
            }
          ],
          "default": []
        }
      },
      {
        "id": "speckit_tasks",
        "value": {
          "type": "script",
          "path": "u/devgodzilla/speckit_tasks_api",
          "input_transforms": {
            "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
            "plan_path": { "type": "javascript", "expr": "results.speckit_plan.plan_path" },
            "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" }
          }
        },
        "input_transforms": {}
      },
      {
        "id": "optional_analyze",
        "value": {
          "type": "branchone",
          "branches": [
            {
              "summary": "Generate analysis report",
              "expr": "!!flow_input.run_analysis",
              "modules": [
                {
                  "id": "speckit_analyze",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/speckit_analyze_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
                    "plan_path": { "type": "javascript", "expr": "results.speckit_plan.plan_path" },
                    "tasks_path": { "type": "javascript", "expr": "results.speckit_tasks.tasks_path" },
                    "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" }
                  }
                }
              ]
            },
            {
              "summary": "Skip analysis",
              "expr": "true",
              "modules": []
            }
          ],
          "default": []
        }
      },
      {
        "id": "delivery_mode",
        "value": {
          "type": "branchone",
          "branches": [
            {
              "summary": "Stop at tasks",
              "expr": "flow_input.output_mode === 'tasks_only'",
              "modules": []
            },
            {
              "summary": "Create task-cycle protocol",
              "expr": "flow_input.output_mode === 'task_cycle'",
              "modules": [
                {
                  "id": "create_protocol",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/protocol_from_spec_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
                    "tasks_path": { "type": "javascript", "expr": "results.speckit_tasks.tasks_path" },
                    "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" },
                    "protocol_name": { "type": "javascript", "expr": "flow_input.protocol_name || ''" },
                    "overwrite": { "type": "javascript", "expr": "flow_input.overwrite_protocol || false" }
                  }
                },
                {
                  "id": "protocol_start",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/protocol_plan_and_wait"
                  },
                  "input_transforms": {
                    "protocol_run_id": { "type": "javascript", "expr": "results.create_protocol.protocol.id" },
                    "timeout_seconds": { "type": "javascript", "expr": "flow_input.protocol_timeout_seconds || 300" }
                  }
                },
                {
                  "id": "get_task_cycle",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/get_task_cycle_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "protocol_run_id": { "type": "javascript", "expr": "results.create_protocol.protocol.id" }
                  }
                }
              ]
            },
            {
              "summary": "Import tasks into existing sprint",
              "expr": "flow_input.output_mode === 'tasks_to_sprint'",
              "modules": [
                {
                  "id": "sync_tasks",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/sync_tasks_api"
                  },
                  "input_transforms": {
                    "sprint_id": { "type": "javascript", "expr": "flow_input.sprint_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_tasks.tasks_path" },
                    "overwrite_existing": { "type": "javascript", "expr": "flow_input.overwrite_existing_tasks || false" }
                  }
                }
              ]
            },
            {
              "summary": "Create protocol",
              "expr": "flow_input.output_mode === 'protocol'",
              "modules": [
                {
                  "id": "create_protocol",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/protocol_from_spec_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
                    "tasks_path": { "type": "javascript", "expr": "results.speckit_tasks.tasks_path" },
                    "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" },
                    "protocol_name": { "type": "javascript", "expr": "flow_input.protocol_name || ''" },
                    "overwrite": { "type": "javascript", "expr": "flow_input.overwrite_protocol || false" }
                  }
                },
                {
                  "id": "protocol_start",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/protocol_plan_and_wait"
                  },
                  "input_transforms": {
                    "protocol_run_id": { "type": "javascript", "expr": "results.create_protocol.protocol.id" },
                    "timeout_seconds": { "type": "javascript", "expr": "flow_input.protocol_timeout_seconds || 300" }
                  }
                }
              ]
            },
            {
              "summary": "Create protocol and sprint",
              "expr": "flow_input.output_mode === 'protocol_to_sprint'",
              "modules": [
                {
                  "id": "create_protocol",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/protocol_from_spec_api"
                  },
                  "input_transforms": {
                    "project_id": { "type": "javascript", "expr": "results.onboard_project.project_id" },
                    "spec_path": { "type": "javascript", "expr": "results.speckit_specify.spec_path" },
                    "tasks_path": { "type": "javascript", "expr": "results.speckit_tasks.tasks_path" },
                    "spec_run_id": { "type": "javascript", "expr": "results.speckit_specify.spec_run_id" },
                    "protocol_name": { "type": "javascript", "expr": "flow_input.protocol_name || ''" },
                    "overwrite": { "type": "javascript", "expr": "flow_input.overwrite_protocol || false" }
                  }
                },
                {
                  "id": "protocol_start",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/protocol_plan_and_wait"
                  },
                  "input_transforms": {
                    "protocol_run_id": { "type": "javascript", "expr": "results.create_protocol.protocol.id" },
                    "timeout_seconds": { "type": "javascript", "expr": "flow_input.protocol_timeout_seconds || 300" }
                  }
                },
                {
                  "id": "create_sprint",
                  "value": {
                    "type": "script",
                    "path": "u/devgodzilla/sprint_from_protocol_api"
                  },
                  "input_transforms": {
                    "protocol_id": { "type": "javascript", "expr": "results.create_protocol.protocol.id" },
                    "sprint_name": { "type": "javascript", "expr": "flow_input.sprint_name || null" },
                    "auto_sync": { "type": "javascript", "expr": "flow_input.auto_sync_sprint !== false" }
                  }
                }
              ]
            }
          ],
          "default": []
        }
      }
    ]
  },
  "schema": {
    "type": "object",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Brownfield Feature Flow",
    "properties": {
      "project_id": {
        "type": "integer",
        "description": "Use an existing DevGodzilla project when available."
      },
      "git_url": {
        "type": "string",
        "description": "Git repository URL. Required only when project_id is not provided.",
        "default": ""
      },
      "project_name": {
        "type": "string",
        "description": "Display name for a new DevGodzilla project.",
        "default": ""
      },
      "branch": {
        "type": "string",
        "description": "Repository branch to analyze and plan against.",
        "default": "main"
      },
      "project_description": {
        "type": "string",
        "description": "Optional short project context for onboarding.",
        "default": ""
      },
      "feature_request": {
        "type": "string",
        "description": "Customer-facing outcome to implement in this brownfield project.",
        "default": ""
      },
      "feature_name": {
        "type": "string",
        "description": "Optional short slug for the feature/spec.",
        "default": ""
      },
      "output_mode": {
        "type": "string",
        "description": "Choose where the flow should stop.",
        "enum": ["task_cycle", "tasks_only", "tasks_to_sprint", "protocol", "protocol_to_sprint"],
        "default": "protocol"
      },
      "run_discovery_agent": {
        "type": "boolean",
        "description": "Run repository discovery during onboarding for unfamiliar codebases.",
        "default": false
      },
      "discovery_pipeline": {
        "type": "boolean",
        "description": "Use the discovery pipeline when onboarding runs.",
        "default": true
      },
      "discovery_engine_id": {
        "type": "string",
        "description": "Optional discovery engine override.",
        "default": ""
      },
      "discovery_model": {
        "type": "string",
        "description": "Optional discovery model override.",
        "default": ""
      },
      "clone_if_missing": {
        "type": "boolean",
        "description": "Clone the repository when it is not already present locally.",
        "default": true
      },
      "constitution_content": {
        "type": "string",
        "description": "Optional custom SpecKit constitution content.",
        "default": ""
      },
      "clarification_entries": {
        "type": "array",
        "description": "Optional clarification Q/A pairs to fold into the spec before planning.",
        "default": [],
        "items": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "answer": { "type": "string" }
          },
          "required": ["question", "answer"]
        }
      },
      "clarification_notes": {
        "type": "string",
        "description": "Optional notes to refine the feature request before plan/tasks generation.",
        "default": ""
      },
      "run_checklist": {
        "type": "boolean",
        "description": "Generate a checklist artifact for the spec.",
        "default": false
      },
      "run_analysis": {
        "type": "boolean",
        "description": "Generate an analysis report after tasks are produced.",
        "default": false
      },
      "sprint_id": {
        "type": "integer",
        "description": "Existing sprint ID. Required when output_mode is tasks_to_sprint."
      },
      "sprint_name": {
        "type": "string",
        "description": "Optional sprint name when output_mode is protocol_to_sprint.",
        "default": ""
      },
      "auto_sync_sprint": {
        "type": "boolean",
        "description": "Automatically sync protocol steps into the created sprint.",
        "default": true
      },
      "overwrite_existing_tasks": {
        "type": "boolean",
        "description": "Allow replacing previously imported sprint tasks.",
        "default": false
      },
      "protocol_name": {
        "type": "string",
        "description": "Optional protocol name override.",
        "default": ""
      },
      "overwrite_protocol": {
        "type": "boolean",
        "description": "Overwrite runtime protocol steps if they already exist.",
        "default": false
      },
      "protocol_timeout_seconds": {
        "type": "integer",
        "description": "How long to wait for protocol planning to settle.",
        "default": 300,
        "minimum": 30
      }
    },
    "required": ["feature_request"],
    "oneOf": [
      {
        "required": ["project_id", "feature_request"]
      },
      {
        "required": ["git_url", "project_name", "feature_request"]
      }
    ],
    "allOf": [
      {
        "if": {
          "properties": {
            "output_mode": { "const": "tasks_to_sprint" }
          }
        },
        "then": {
          "required": ["sprint_id"]
        }
      }
    ]
  }
}
